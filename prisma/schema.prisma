generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  phone_number        String?              @unique
  password            String
  stores              Store[]
  createdAt           DateTime             @default(now())
  cartItems           CartItem[]
  orders              Order[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
}

model Session {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Store {
  id   String @id @default(uuid())
  name String
  slug String @unique

  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionEndsAt DateTime?
  gracePeriodEndsAt  DateTime?
  autoRenew          Boolean            @default(true)

  balance      Int @default(0)
  monthlyPrice Int @default(29900)

  paymentMethods String[] @default([])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  products   Product[]
  cartItems  CartItem[]
  orders     Order[]
  categories Category[]
  banners    Banner[]
  settings   StoreSettings?
  visits     Visit[]

  balanceTransactions BalanceTransaction[]
  topupRequests       TopupRequest[]
  serviceRequests     ServiceRequest[]

  coupons        Coupon[]
  appliedCoupons AppliedCoupon[]

  showPoweredByCasho      Boolean @default(true)
  poweredByRemovalEnabled Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([subscriptionStatus])
  @@index([subscriptionEndsAt])
  @@index([gracePeriodEndsAt])
}

model StoreSettings {
  id      String @id @default(uuid())
  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id])

  logo           String?
  coverImage     String?
  primaryColor   String?
  secondaryColor String?
  navbarVariant  String  @default("default")

  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  ogTitle        String?
  ogDescription  String?
  ogImage        String?
  isIndexed      Boolean  @default(true)

  announcementText String?
  description      String?
  email            String?
  whatsappNumber   String?
  instagram        String?
  facebook         String?
  tiktok           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visit {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())

  ip        String?
  userAgent String?

  @@index([storeId, createdAt])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String
  image     String?
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([storeId, slug])
}

model Product {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?

  price          Float
  compareAtPrice Float?

  image  String   @default("/images/product-placeholder.png")
  images String[] @default([])

  brand String?

  stock Int @default(0)

  sizes  String[] @default([])
  colors String[] @default([])
  tags   String[] @default([])

  weight     Float?
  attributes Json?

  isActive    Boolean @default(true)
  isFeatured  Boolean @default(false)
  hasVariants Boolean @default(false)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model Banner {
  id      String @id @default(uuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  title    String
  image    String
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
}

model CartItem {
  id             String @id @default(uuid())
  guestSessionId String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@unique([guestSessionId, productId])
}

model Coupon {
  id          String     @id @default(uuid())
  code        String
  type        CouponType
  value       Float
  isActive    Boolean    @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
  usageLimit  Int?
  usedCount   Int        @default(0)
  minSubtotal Float?
  maxDiscount Float?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  appliedCoupons AppliedCoupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, code])
  @@index([storeId, code, isActive])
}

model AppliedCoupon {
  id             String @id @default(uuid())
  guestSessionId String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([guestSessionId, storeId])
  @@index([couponId])
}

model Order {
  id String @id @default(uuid())

  guestSessionId String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  status        OrderStatus @default(PENDING)
  paymentMethod String

  subtotal Int
  shipping Int @default(0)
  discount Int @default(0)
  total    Int

  couponCode String?

  fullName String
  phone    String
  address  String

  createdAt DateTime @default(now())

  items  OrderItem[]
  userId String?
  user   User?       @relation(fields: [userId], references: [id])
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  price    Int
  quantity Int

  createdAt DateTime @default(now())
}

model BalanceTransaction {
  id String @id @default(uuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  type          BalanceTransactionType
  amount        Int
  balanceBefore Int
  balanceAfter  Int

  note      String?
  reference String?

  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  GRACE_PERIOD
  PAST_DUE
  CANCELED
}

enum BalanceTransactionType {
  TOPUP
  SUBSCRIPTION_CHARGE
  BONUS
  MANUAL_ADJUSTMENT
  REFUND
}

enum TopupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TopupMethod {
  VODAFONE_CASH
  INSTAPAY
  BANK_TRANSFER
}

model TopupRequest {
  id           String             @id @default(uuid())
  amount       Int
  method       TopupMethod
  status       TopupRequestStatus @default(PENDING)
  note         String?
  transferRef  String?
  receiptImage String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ServiceRequestStatus {
  PENDING
  CONTACTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

model ServiceRequest {
  id String @id @default(uuid())

  serviceId    String
  serviceTitle String

  fullName  String
  phone     String
  whatsapp  String?
  storeLink String?
  notes     String?

  status ServiceRequestStatus @default(PENDING)

  adminNote   String?
  handledAt   DateTime?
  handledById String?

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([storeId, createdAt])
  @@index([serviceId, status])
}
